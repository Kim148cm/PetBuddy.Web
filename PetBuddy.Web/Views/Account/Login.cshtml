@model PetBuddy.Web.Models.LoginViewModel
@{
    ViewBag.Title = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ===== AUTH PAGE ===== */
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 60px 20px 80px 20px;
        background: #ff7a1a;
        min-height: 80vh;
    }

    .auth-box {
        width: 100%;
        max-width: 950px;
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

    /* LEFT */
    .auth-left {
        width: 50%;
        background: linear-gradient(135deg, #ff7a1a, #ff5e00);
        color: #fff;
        padding: 60px 50px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .auth-left h1 {
            font-size: 42px;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .auth-left p {
            font-size: 16px;
            line-height: 1.6;
        }

    /* RIGHT */
    .auth-right {
        width: 50%;
        padding: 60px 50px;
        background: #f9f9f9;
    }

        .auth-right h2 {
            text-align: center;
            margin-bottom: 30px;
            font-size: 26px;
            font-weight: 700;
        }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            font-weight: 600;
            font-size: 14px;
        }

    .form-control {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #ddd;
        margin-top: 6px;
        font-size: 14px;
    }

        .form-control:focus {
            outline: none;
            border-color: #ff7a1a;
        }

    .btn-login {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        background: #ff6a00;
        color: #fff;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        margin-top: 10px;
    }

        .btn-login:hover {
            background: #e65c00;
        }

    .text-center {
        text-align: center;
        margin-top: 15px;
        font-size: 14px;
    }

        .text-center a {
            color: #ff6a00;
            font-weight: 600;
        }

            .text-center a:hover {
                text-decoration: underline;
            }

    .error {
        background: #ffe0e0;
        color: red;
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 15px;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-box">

        <!-- LEFT -->
        <div class="auth-left">
            <h1>PetBuddy</h1>
            <p>Chào mừng bạn quay lại!</p>
            <p>Đăng nhập để tiếp tục sử dụng các dịch vụ của chúng tôi.</p>
        </div>

        <!-- RIGHT -->
        <div class="auth-right">
            <h2>Đăng nhập</h2>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error">
                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                </div>
            }

            @using (Html.BeginForm("Login", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label>Email</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Email" })
                </div>

                <div class="form-group">
                    <label>Mật khẩu</label>
                    @Html.PasswordFor(m => m.MatKhau, new { @class = "form-control", placeholder = "Mật khẩu" })
                </div>

                <button type="submit" class="btn-login">ĐĂNG NHẬP</button>

                <div class="text-center">
                    <a href="@Url.Action("ForgotPassword","Account")">Quên mật khẩu?</a>
                </div>

                <div class="text-center">
                    Bạn chưa có tài khoản?
                    <a href="@Url.Action("Register","Account")">Đăng ký</a>
                </div>
            }
        </div>

    </div>
</div>
