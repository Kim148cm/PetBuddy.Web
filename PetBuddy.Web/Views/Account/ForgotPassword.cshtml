@model PetBuddy.Web.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "Quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 60px 20px 80px 20px;
        background: #ff7a1a;
        min-height: 80vh;
    }

    .auth-box {
        width: 100%;
        max-width: 950px;
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

    .auth-left {
        width: 50%;
        background: linear-gradient(135deg, #ff7a1a, #ff5e00);
        color: #fff;
        padding: 60px 50px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .auth-left h1 {
            font-size: 42px;
            font-weight: 800;
        }

    .auth-right {
        width: 50%;
        padding: 60px 50px;
        background: #f9f9f9;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #ddd;
        margin-top: 10px;
    }

    .btn-auth {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        background: #ff6a00;
        color: #fff;
        font-weight: 700;
        margin-top: 15px;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-box">

        <div class="auth-left">
            <h1>PetBuddy</h1>
            <p>Nhập email để đặt lại mật khẩu của bạn.</p>
        </div>

        <div class="auth-right">
            <h2>Quên mật khẩu</h2>

            @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Nhập email" })

                <button type="submit" class="btn-auth">Gửi yêu cầu</button>

                <div class="text-center">
                    <a href="@Url.Action("Login","Account")">Quay lại đăng nhập</a>
                </div>
            }
        </div>

    </div>
</div>
