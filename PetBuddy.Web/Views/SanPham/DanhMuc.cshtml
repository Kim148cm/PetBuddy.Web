@model List<PetBuddy.Web.Models.SanPham>

@{
    ViewBag.Title = "Thức ăn cho mèo";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    /* ================= BANNER ================= */

    .category-banner {
        position: relative;
        width: 100%;
        height: 320px;
        margin-bottom: 40px;
        overflow: hidden;
        border-radius: 10px;
    }

        .category-banner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .category-banner::after {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.45);
        }

    .banner-overlay {
        position: absolute;
        bottom: 50px;
        left: 60px;
        color: white;
        z-index: 2;
    }

        .banner-overlay h2 {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .banner-overlay p {
            font-size: 18px;
        }

    /* ================= SIDEBAR ================= */

    .sidebar {
        border-right: 1px solid #eee;
        padding-right: 20px;
    }

    /* ================= PRODUCT ================= */

    .product-card {
        transition: 0.3s;
        border: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

    .product-img {
        height: 200px;
        object-fit: contain;
        padding: 15px;
    }

    .price {
        font-weight: 600;
        color: #000;
    }

    .out-stock {
        position: absolute;
        top: 10px;
        right: 10px;
        background: red;
        color: white;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 4px;
    }
</style>

<!-- ================= BANNER ================= -->

<div class="container mt-4">
    <div class="category-banner">
        <img src="~/Content/images/banner-meo.jpg" alt="Thức ăn cho mèo" />
        <div class="banner-overlay">
            <h2>Thức ăn dinh dưỡng cho mèo</h2>
            <p>Đảm bảo sức khỏe & phát triển toàn diện</p>
        </div>
    </div>
</div>

<!-- ================= MAIN CONTENT ================= -->

<div class="container-fluid">
    <div class="row">

        <!-- SIDEBAR -->
        <div class="col-md-3 sidebar">
            <h6><b>THƯƠNG HIỆU | BRAND</b></h6>
            <div>
                <div><input type="checkbox" /> Royal Canin</div>
                <div><input type="checkbox" /> Whiskas</div>
                <div><input type="checkbox" /> Nekko</div>
                <div><input type="checkbox" /> KitCat</div>
            </div>

            <hr />

            <h6><b>GIÁ SẢN PHẨM | PRICE</b></h6>
            <div>
                <div><input type="checkbox" /> Dưới 50,000đ</div>
                <div><input type="checkbox" /> 50,000đ - 100,000đ</div>
                <div><input type="checkbox" /> Trên 100,000đ</div>
            </div>
        </div>

        <!-- PRODUCT LIST -->
        <div class="col-md-9">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3>Thức ăn cho mèo</h3>

                <select class="form-select w-auto">
                    <option>Bán chạy nhất</option>
                    <option>Giá thấp đến cao</option>
                    <option>Giá cao đến thấp</option>
                </select>
            </div>

            <div class="row">

                @foreach (var sp in Model)
                {
                    <div class="col-md-3 mb-4">
                        <div class="card product-card position-relative h-100">

                            @if (sp.SoLuong == 0)
                            {
                                <div class="out-stock">Hết hàng</div>
                            }

                            <img src="~/Content/images/default.png"
                                 class="card-img-top product-img"
                                 alt="@sp.TenSanPham" />

                            <div class="card-body text-center">
                                <h6>@sp.TenSanPham</h6>
                                <p class="price">
                                    @String.Format("{0:N0}", sp.Gia) đ
                                </p>
                            </div>

                        </div>
                    </div>
                }

            </div>

        </div>

    </div>
</div>